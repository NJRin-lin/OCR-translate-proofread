<Application x:Class="NGMproofread.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Design colors -->
        <Color x:Key="ConfidenceHighColor">#34C759</Color>
        <Color x:Key="ConfidenceMidColor">#FF9500</Color>
        <Color x:Key="ConfidenceLowColor">#FF3B30</Color>
        <Color x:Key="GrammarPurpleColor">#AF52DE</Color>
        <Color x:Key="PartOfSpeechBlueColor">#007AFF</Color>
        <Color x:Key="JlptOrangeColor">#FF9500</Color>
        <Color x:Key="NotesYellowColor">#FFCC00</Color>

        <SolidColorBrush x:Key="ConfidenceHighBrush" Color="{StaticResource ConfidenceHighColor}" />
        <SolidColorBrush x:Key="ConfidenceMidBrush" Color="{StaticResource ConfidenceMidColor}" />
        <SolidColorBrush x:Key="ConfidenceLowBrush" Color="{StaticResource ConfidenceLowColor}" />
        <SolidColorBrush x:Key="GrammarPurpleBrush" Color="{StaticResource GrammarPurpleColor}" />
        <SolidColorBrush x:Key="PartOfSpeechBlueBrush" Color="{StaticResource PartOfSpeechBlueColor}" />
        <SolidColorBrush x:Key="JlptOrangeBrush" Color="{StaticResource JlptOrangeColor}" />
        <SolidColorBrush x:Key="NotesYellowBrush" Color="{StaticResource NotesYellowColor}" />

        <!-- Default styles -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style TargetType="TextBlock" x:Key="CaptionText">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </Style>
    </Application.Resources>
</Application>
