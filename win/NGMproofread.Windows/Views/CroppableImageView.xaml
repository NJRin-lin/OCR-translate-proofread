<UserControl x:Class="NGMproofread.Windows.Views.CroppableImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Image area with crop overlay -->
        <Border Grid.Row="0" Background="Transparent" ClipToBounds="True">
            <Grid x:Name="ImageGrid" ClipToBounds="True"
                  MouseLeftButtonDown="ImageGrid_MouseLeftButtonDown"
                  MouseLeftButtonUp="ImageGrid_MouseLeftButtonUp"
                  MouseMove="ImageGrid_MouseMove"
                  MouseWheel="ImageGrid_MouseWheel"
                  MouseEnter="ImageGrid_MouseEnter"
                  MouseLeave="ImageGrid_MouseLeave"
                  Cursor="Cross">
                <!-- Image element -->
                <Image x:Name="MainImage" Stretch="Uniform"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="ImageTranslate" X="0" Y="0" />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <!-- Crop overlay canvas -->
                <Canvas x:Name="CropCanvas" IsHitTestVisible="False" />
            </Grid>
        </Border>

        <!-- Zoom toolbar -->
        <Border Grid.Row="1" Padding="8,4" Background="#80F0F0F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="🖼 上传图片" Padding="8,4"
                        Click="UploadImageBtn_Click" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ResetZoomBtn" Content="1:1" Padding="6,2"
                            Width="36" ToolTip="重置缩放"
                            Click="ResetZoomBtn_Click"
                            Visibility="Collapsed" />
                    <Button Content="−" Width="28" Padding="0" Margin="2,0"
                            Click="ZoomOutBtn_Click" ToolTip="缩小" />
                    <TextBlock x:Name="ZoomPercentText" Text="100%" Width="40"
                               TextAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray" FontSize="14" />
                    <Button Content="+" Width="28" Padding="0"
                            Click="ZoomInBtn_Click" ToolTip="放大" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Selection toolbar -->
        <Border Grid.Row="2" Padding="8,6" Background="#E8F0F0F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Hint text -->
                <TextBlock x:Name="ToolbarHintText" Grid.Column="0"
                           Text="滑动平移 · 滚轮缩放" FontSize="14"
                           Foreground="Gray" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="200" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Clear selection -->
                    <Button x:Name="ClearSelectionBtn" Content="✕ 清除选区"
                            Padding="8,4" Margin="0,0,8,0"
                            Click="ClearSelectionBtn_Click"
                            Visibility="Collapsed" Foreground="Orange" />

                    <!-- Full image -->
                    <Button Content="全图识别" Padding="8,4" Margin="0,0,8,0"
                            Click="FullImageBtn_Click" />

                    <!-- Dynamic: Enter selection / Cancel / Confirm -->
                    <Button x:Name="EnterSelectionBtn" Content="选区识别"
                            Padding="12,6" FontWeight="Bold"
                            Click="EnterSelectionBtn_Click" />
                    <Button x:Name="CancelSelectionBtn" Content="✕ 取消"
                            Padding="8,4"
                            Click="CancelSelectionBtn_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="ConfirmSelectionBtn" Content="✓ 确认"
                            Padding="12,6" FontWeight="Bold"
                            Click="ConfirmSelectionBtn_Click"
                            Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty state overlay -->
        <Grid x:Name="EmptyStateOverlay" Grid.Row="0" Visibility="Visible"
              Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🖼" FontSize="48" HorizontalAlignment="Center"
                           Foreground="Gray" />
                <TextBlock Text="上传图片开始识别" FontSize="14"
                           Foreground="Gray" HorizontalAlignment="Center"
                           Margin="0,12,0,20" />
                <StackPanel HorizontalAlignment="Center">
                    <Button Content="🖼 上传图片" Width="160" Padding="12,8"
                            FontWeight="Bold"
                            Click="UploadImageBtn_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
