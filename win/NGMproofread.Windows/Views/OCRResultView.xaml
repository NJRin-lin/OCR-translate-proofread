<UserControl x:Class="NGMproofread.Windows.Views.OCRResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="识别结果" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- TTS button (shown in continuous mode) -->
                    <Button x:Name="TTSButton" Content="▶ 朗读" Padding="6,3"
                            FontSize="15" Margin="0,0,6,0"
                            Click="TTSButton_Click" Visibility="Collapsed" />

                    <!-- Toggle segment/continuous -->
                    <Button x:Name="ViewToggleBtn" Content="连贯" Padding="6,3"
                            FontSize="15" Click="ViewToggleBtn_Click" />

                    <!-- Confidence badge -->
                    <Border x:Name="ConfidenceBadge" CornerRadius="10"
                            Padding="8,3" Margin="8,0,0,0"
                            Background="#1A34C759" VerticalAlignment="Center">
                        <TextBlock x:Name="ConfidenceBadgeText" FontSize="15"
                                   Foreground="Gray" />
                    </Border>
                </StackPanel>
            </Grid>

            <Separator Margin="0,0,0,8" />

            <!-- Continuous text view -->
            <TextBox x:Name="ContinuousTextView" TextWrapping="Wrap"
                     IsReadOnly="True" FontSize="14"
                     BorderBrush="Transparent"
                     Background="#0D000000"
                     Padding="8" Visibility="Collapsed"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="60" />

            <!-- Segmented view -->
            <ItemsControl x:Name="SegmentedList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Text}"
                                           FontSize="14" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" Text="{Binding ConfidenceDisplay}"
                                           FontSize="14" Margin="6,0,0,0"
                                           VerticalAlignment="Top"
                                           Foreground="{Binding ConfidenceBrush}" />
                            </Grid>
                            <Rectangle Height="0.5" Fill="#20000000" Margin="8,2" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Low confidence warning -->
            <Border x:Name="LowConfidenceWarning" Visibility="Collapsed"
                    Margin="0,8,0,0" Padding="8,4"
                    CornerRadius="4"
                    Background="#26FFCC00">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="15" Foreground="#FFCC00"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="黄色标记部分置信度较低，请核对"
                               FontSize="15" Foreground="Gray" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
