<UserControl x:Class="NGMproofread.Windows.Views.TranslationResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <!-- Header -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="翻译结果" FontSize="14" FontWeight="Bold" />
            <!-- Language direction badge -->
            <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                    Background="#0D000000">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🇯🇵 日文" FontSize="11" Foreground="Gray" />
                    <TextBlock Text=" → " FontSize="11" Foreground="Gray" />
                    <TextBlock Text="🇨🇳 中文" FontSize="11" Foreground="Gray" />
                </StackPanel>
            </Border>
        </Grid>

        <Separator Margin="0,0,0,8" />

        <!-- Original text -->
        <StackPanel Margin="0,0,0,8">
            <TextBlock Text="原文" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
            <TextBox x:Name="OriginalText" IsReadOnly="True" TextWrapping="Wrap"
                     FontSize="14" Background="#0D000000"
                     BorderBrush="Transparent" Padding="8"
                     VerticalScrollBarVisibility="Auto" MinHeight="40" />
        </StackPanel>

        <!-- Translated text -->
        <StackPanel>
            <TextBlock Text="中文" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
            <TextBox x:Name="TranslatedText" IsReadOnly="True" TextWrapping="Wrap"
                     FontSize="14" BorderBrush="Transparent"
                     Padding="0" VerticalScrollBarVisibility="Auto" />
        </StackPanel>
    </StackPanel>
</UserControl>
